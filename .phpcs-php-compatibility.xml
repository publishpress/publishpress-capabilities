<?xml version="1.0"?>
<ruleset xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" name="PHPCompatibility"
         xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/squizlabs/PHP_CodeSniffer/master/phpcs.xsd">
    <description>Check PHP compatibility across supported versions</description>

    <arg name="extensions" value="php"/>
    <arg name="colors"/>
    <ini name="memory_limit" value="256M"/>
    <arg name="basepath" value="."/>
    <arg name="parallel" value="20"/>

    <file>includes/</file>
    <file>includes-core/</file>
    <file>framework/</file>
    <file>capsman-enhanced.php</file>

    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*/dist/*</exclude-pattern>
    <exclude-pattern>*/lib/vendor/*</exclude-pattern>

    <rule ref="PHPCompatibility"/>
</ruleset>
